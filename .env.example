# =============================================================================
# iGoTrend VPS Environment Variables
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
# =============================================================================

# --- PostgreSQL (used by the postgres container) ---
POSTGRES_USER=igotrend
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=igotrend

# --- Database URL (used by the API container) ---
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# For docker-compose, the host is the postgres service name.
DATABASE_URL=postgresql://igotrend:changeme_strong_password_here@postgres:5432/igotrend

# --- Authentication ---
JWT_SECRET=changeme_at_least_32_random_characters_here

# --- Application URLs ---
# The public-facing base URL for the web app (no trailing slash).
# Used in transactional emails and notification links sent to creators/brands.
APP_BASE_URL=https://app.yourdomain.com
# The public-facing base URL for the admin panel (no trailing slash).
ADMIN_BASE_URL=https://admin.yourdomain.com
# URL used in payment/billing redirects (e.g. Stripe return URL).
APP_URL=https://app.yourdomain.com

# --- Logging ---
# Options: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Object / File Storage ---
# Directory for private uploads (must be writable by the API container).
PRIVATE_OBJECT_DIR=/app/storage/private
# Comma-separated public path prefixes for object storage ACL checks.
PUBLIC_OBJECT_SEARCH_PATHS=/storage/public

# --- Docker registry (used by docker-compose to pull images) ---
DOCKER_USERNAME=your_dockerhub_username
# DOCKER_REGISTRY=ghcr.io  # Uncomment to use GitHub Container Registry instead

# --- Google Cloud Storage (optional — only if GCS is configured) ---
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs-key.json
# GCS_BUCKET_NAME=your-bucket-name

# --- Email (SMTP / Nodemailer) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=noreply@yourdomain.com

# --- OpenAI (optional — only if AI features are enabled) ---
# OPENAI_API_KEY=sk-...
